rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────
    // Helper functions
    // ──────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isPro() {
      return isSignedIn() && getUserRole() in ['pro', 'admin'];
    }

    function isNotDemo() {
      return !('isDemo' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDemo != true;
    }

    // ──────────────────────────────
    // users
    // ──────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
                    && !('role' in request.resource.data);
      allow update: if (isAdmin() && isNotDemo())
                    || (isOwner(userId) && isNotDemo()
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'stripeCustomerId', 'subscriptionId',
                                     'subscriptionStatus', 'subscriptionCurrentPeriodEnd',
                                     'subscriptionTrialEnd',
                                     'xp', 'level', 'rank', 'achievements']));
      allow delete: if isAdmin();

      // likes
      match /likes/{dartId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) && isNotDemo();
      }

      // bookmarks
      match /bookmarks/{dartId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) && isNotDemo();
      }

      // barrelBookmarks
      match /barrelBookmarks/{barrelId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) && isNotDemo();
      }

      // dartsLiveStats
      match /dartsLiveStats/{statsId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isPro() && isNotDemo();
        allow update: if isOwner(userId) && isPro() && isNotDemo();
        allow delete: if isOwner(userId);
      }

      // settingHistory
      match /settingHistory/{historyId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isNotDemo();
      }

      // xpHistory (read: owner, write: backend only via Admin SDK)
      match /xpHistory/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // dartsliveCache (backend only via Admin SDK)
      match /dartsliveCache/{docId} {
        allow read, write: if false;
      }

      // goals
      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isNotDemo();
        allow update: if isOwner(userId) && isNotDemo();
        allow delete: if isOwner(userId) && isNotDemo();
      }

      // shopBookmarks
      match /shopBookmarks/{bookmarkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isNotDemo();
        allow update: if isOwner(userId) && isNotDemo();
        allow delete: if isOwner(userId) && isNotDemo();
      }

      // shopLists
      match /shopLists/{listId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isNotDemo();
        allow update: if isOwner(userId) && isNotDemo();
        allow delete: if isOwner(userId) && isNotDemo();
      }

      // healthMetrics
      match /healthMetrics/{dateId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isNotDemo();
        allow delete: if isOwner(userId) && isNotDemo();
      }

      // focusPoints（練習の意識ポイント）
      match /focusPoints/{docId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isNotDemo();
      }

    }

    // ──────────────────────────────
    // darts
    // ──────────────────────────────
    match /darts/{dartId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotDemo()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isNotDemo() && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isNotDemo() && (isOwner(resource.data.userId) || isAdmin());

      // comments
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotDemo()
                      && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && isNotDemo()
                      && (resource.data.userId == request.auth.uid || isAdmin());
      }

      // memos (owner only)
      match /memos/{memoId} {
        allow read: if isSignedIn()
                    && get(/databases/$(database)/documents/darts/$(dartId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && isNotDemo()
                      && request.resource.data.userId == request.auth.uid
                      && get(/databases/$(database)/documents/darts/$(dartId)).data.userId == request.auth.uid;
        allow delete: if isSignedIn() && isNotDemo()
                      && get(/databases/$(database)/documents/darts/$(dartId)).data.userId == request.auth.uid;
      }
    }

    // ──────────────────────────────
    // articles
    // ──────────────────────────────
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isNotDemo()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() && isNotDemo();
      allow delete: if isAdmin() && isNotDemo();
    }

    // ──────────────────────────────
    // discussions
    // ──────────────────────────────
    match /discussions/{discussionId} {
      allow read: if true;

      allow create: if isPro() && isNotDemo()
                    && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() && isNotDemo()
                    && (
                      // admin: 全フィールド更新可
                      isAdmin()
                      // 作者(pro): 自分のスレッドの内容のみ
                      || (isPro()
                          && resource.data.userId == request.auth.uid
                          && request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['title', 'content', 'category', 'updatedAt']))
                      // 返信時の replyCount/lastRepliedAt 更新（+1のみ許可）
                      || (isSignedIn()
                          && request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['replyCount', 'lastRepliedAt'])
                          && request.resource.data.replyCount == resource.data.replyCount + 1)
                    );

      allow delete: if isNotDemo()
                    && (isAdmin()
                    || (isPro() && resource.data.userId == request.auth.uid));

      // replies
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && isNotDemo()
                      && request.resource.data.userId == request.auth.uid
                      && get(/databases/$(database)/documents/discussions/$(discussionId)).data.isLocked == false;
        allow delete: if isSignedIn() && isNotDemo()
                      && (resource.data.userId == request.auth.uid || isAdmin());
        allow update: if false;
      }
    }

    // ──────────────────────────────
    // barrels (read-only, populated by scripts via Admin SDK)
    // ──────────────────────────────
    match /barrels/{barrelId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────
    // barrelRanking (read-only)
    // ──────────────────────────────
    match /barrelRanking/{rankId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────
    // config (read-only, admin updates via API)
    // ──────────────────────────────
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────
    // stripeEvents / lineConversations / lineLinkCodes
    // (backend only via Admin SDK)
    // ──────────────────────────────
    match /stripeEvents/{eventId} {
      allow read, write: if false;
    }

    match /lineConversations/{lineUserId} {
      allow read, write: if false;
    }

    match /lineLinkCodes/{code} {
      allow read, write: if false;
    }

    // ──────────────────────────────
    // reports (通報: 認証ユーザーのみ作成可)
    // ──────────────────────────────
    match /reports/{reportId} {
      allow create: if isSignedIn() && isNotDemo()
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
